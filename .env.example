# =============================================================================
# Anchor Environment Configuration (v2.8.1)
# =============================================================================
# Copy this file to .env and customize for your environment.
# All variables are prefixed with ANCHOR_ and are optional.
# =============================================================================

# Override the constitution URL for air-gapped / corporate mirror setups.
# Default: https://raw.githubusercontent.com/Tanishq1030/Anchor/main/constitution.anchor
# ANCHOR_CONSTITUTION_URL=https://internal-mirror.company.com/anchor/constitution.anchor

# Override the mitigation catalog URL for air-gapped / corporate mirror setups.
# Default: https://raw.githubusercontent.com/Tanishq1030/Anchor/main/mitigation.anchor
# ANCHOR_MITIGATION_URL=https://internal-mirror.company.com/anchor/mitigation.anchor

# Enable verbose debug output for all Anchor commands.
# Default: false
# ANCHOR_VERBOSE=false

# Timeout (seconds) for fetching governance files from the cloud.
# Default: 10
# ANCHOR_FETCH_TIMEOUT=10
