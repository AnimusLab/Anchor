# =============================================================================
# MANIFEST.in — Controls what goes into the source distribution (sdist)
# =============================================================================
# The universal constitution and mitigation catalog live in the repo for 
# GitHub Raw serving, but are EXCLUDED from PyPI packages. 
# Only the .example references ship.
# =============================================================================

include README.md
include USAGE.md
include LICENSE
recursive-include anchor *.py
recursive-include anchor/core/resources *

# Exclude the universal files from the sdist
# (they are served from GitHub Raw, not bundled with the package)
exclude constitution.anchor
exclude mitigation.anchor
exclude finos-master.anchor