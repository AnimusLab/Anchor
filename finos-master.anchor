# =============================================================================
# FINOS AI Governance Framework - Universal Constitution
# =============================================================================
# Version: 2.3.0
# Status: PRODUCTION
# Authority: FINOS (Fintech Open Source Foundation)
# 
# This file represents the "Federal Law" - universal rules that ALL projects
# under FINOS governance must follow. Individual projects can extend but
# CANNOT weaken these rules.
#
# HOW TO READ THIS FILE:
# - Each rule has an ID (e.g., FINOS-001, RI-24) that maps to a specific risk
# - Rules marked "blocker" will FAIL the build and block merges
# - Rules marked "error" will fail but can be overridden locally
# - Rules marked "warning" will notify but allow the build to proceed
#
# HOW TO OVERRIDE LOCALLY:
# Create a policy.anchor file in your project root with:
#   - Same rule ID to override severity/message
#   - New rule IDs to add project-specific rules
# =============================================================================

version: "2.3"

metadata:
  framework: "FINOS AI Governance Framework"
  version: "2.3.0"
  last_updated: "2026-02-07"
  maintainer: "FINOS Security Working Group"
  repository: "https://github.com/finos/anchor-rules"
  
# =============================================================================
# SECTION 1: CODE EXECUTION RULES
# These rules prevent arbitrary code execution vulnerabilities
# =============================================================================

rules:
  - id: "FINOS-001"
    name: "Ban Dynamic Code Execution (eval)"
    category: "code_execution"
    description: |
      The eval() function executes arbitrary Python code from strings.
      This is a critical security vulnerability in AI systems where
      inputs may come from untrusted sources (models, prompts, APIs).
    match:
      type: "function_call"
      name: "eval"
    message: "FINOS-001: Dynamic code execution via eval() is forbidden."
    severity: "blocker"
    mitigation: "Use ast.literal_eval() for safe literal parsing, or refactor to avoid dynamic execution."
    references:
      - "https://owasp.org/Top10/A03_2021-Injection/"
      - "https://finos.github.io/ai-governance/risks/code-execution"

  - id: "FINOS-002"
    name: "Ban Dynamic Code Execution (exec)"
    category: "code_execution"
    match:
      type: "function_call"
      name: "exec"
    message: "FINOS-002: Dynamic code execution via exec() is forbidden."
    severity: "blocker"
    mitigation: "Refactor to use explicit function calls instead of dynamic execution."

  - id: "FINOS-003"
    name: "Ban Compile for Code Generation"
    category: "code_execution"
    match:
      type: "function_call"
      name: "compile"
    message: "FINOS-003: compile() for code generation is restricted."
    severity: "error"
    mitigation: "Only use compile() for static template rendering with trusted inputs."

# =============================================================================
# SECTION 2: SUPPLY CHAIN / NETWORK RULES
# These rules prevent unauthorized data exfiltration and supply chain attacks
# =============================================================================

  - id: "RI-24"
    name: "Supply Chain Attack - Raw Network Access"
    category: "network"
    description: |
      Direct use of HTTP libraries (requests, httpx) bypasses security controls.
      AI agents with network access can exfiltrate training data, model weights,
      or sensitive business logic.
    match:
      type: "import"
      module: "requests"
    message: "RI-24: Raw network access forbidden. Use approved MCP/SecureClient."
    severity: "blocker"
    mitigation: |
      Replace 'import requests' with your organization's approved HTTP client.
      Example: from anchor.net import SecureClient
    references:
      - "https://finos.github.io/ai-governance/risks/supply-chain"

  - id: "RI-24-HTTPX"
    name: "Supply Chain Attack - Raw Network Access (httpx)"
    category: "network"
    match:
      type: "import"
      module: "httpx"
    message: "RI-24: Raw network access via httpx forbidden."
    severity: "blocker"

  - id: "RI-24-AIOHTTP"
    name: "Supply Chain Attack - Raw Network Access (aiohttp)"
    category: "network"
    match:
      type: "import"
      module: "aiohttp"
    message: "RI-24: Raw network access via aiohttp forbidden."
    severity: "error"

  - id: "RI-25"
    name: "WebSocket Without Approval"
    category: "network"
    match:
      type: "import"
      module: "websockets"
    message: "RI-25: WebSocket connections require security review."
    severity: "warning"

# =============================================================================
# SECTION 3: UNSAFE DESERIALIZATION
# Pickle and similar formats can execute arbitrary code during loading
# =============================================================================

  - id: "AI-15"
    name: "Unsafe Deserialization (pickle)"
    category: "deserialization"
    description: |
      Pickle can execute arbitrary code during deserialization. AI models
      saved as pickle files can contain backdoors that execute when loaded.
    match:
      type: "import"
      module: "pickle"
    message: "AI-15: Pickle deserialization forbidden. Use safetensors or JSON."
    severity: "error"
    mitigation: |
      For model weights: Use safetensors format
      For config: Use JSON or YAML
      For data: Use msgpack or protobuf

  - id: "AI-15-JOBLIB"
    name: "Unsafe Deserialization (joblib)"
    category: "deserialization"
    match:
      type: "import"
      module: "joblib"
    message: "AI-15: Joblib uses pickle internally. Consider alternatives."
    severity: "warning"

  - id: "AI-15-DILL"
    name: "Unsafe Deserialization (dill)"
    category: "deserialization"
    match:
      type: "import"
      module: "dill"
    message: "AI-15: Dill extends pickle with more code execution risks."
    severity: "blocker"

  - id: "AI-15-CLOUDPICKLE"
    name: "Unsafe Deserialization (cloudpickle)"
    category: "deserialization"
    match:
      type: "import"
      module: "cloudpickle"
    message: "AI-15: Cloudpickle serializes functions - high risk."
    severity: "blocker"

# =============================================================================
# SECTION 4: PRIVILEGE ESCALATION
# Rules preventing unauthorized privilege escalation
# =============================================================================

  - id: "RI-12"
    name: "Privilege Escalation via Threading"
    category: "threading"
    description: |
      Direct thread creation bypasses agent isolation and resource limits.
      Malicious code can spawn threads to evade monitoring.
    match:
      type: "inheritance"
      parent: "Thread"
    message: "RI-12: Direct threading forbidden. Use managed TaskQueue."
    severity: "error"
    mitigation: "Use 'from anchor.runtime import TaskQueue' for managed async."

  - id: "RI-12-SUBPROCESS"
    name: "Privilege Escalation via Subprocess"
    category: "subprocess"
    match:
      type: "import"
      module: "subprocess"
    message: "RI-12: Direct subprocess forbidden. Use Diamond Cage sandbox."
    severity: "warning"
    mitigation: "Use 'anchor.core.sandbox.DiamondCage' for safe subprocess execution."

  - id: "RI-12-OS-SYSTEM"
    name: "Privilege Escalation via os.system"
    category: "system"
    match:
      type: "function_call"
      name: "system"
    message: "RI-12: os.system() is forbidden. Use Diamond Cage sandbox."
    severity: "blocker"

  - id: "RI-12-CTYPES"
    name: "Privilege Escalation via ctypes"
    category: "native"
    match:
      type: "import"
      module: "ctypes"
    message: "RI-12: ctypes for native code access requires security review."
    severity: "error"

# =============================================================================
# SECTION 5: MODEL GOVERNANCE RULES
# Rules for validating AI model weights and provenance
# =============================================================================

  - id: "MODEL-001"
    name: "Training Data Provenance Required"
    category: "model_governance"
    check_type: "data_provenance"
    description: |
      All models must document their training data sources to ensure
      compliance with licensing and regulatory requirements.
    allowed_sources:
      - "verified_exchanges"
      - "licensed_datasets"
      - "internal_data"
      - "public_domain"
      - "synthetic_data"
    message: "MODEL-001: Model must include verified training data provenance."
    severity: "blocker"
    mitigation: "Provide training_metadata.json with 'data_sources' field."

  - id: "MODEL-002"
    name: "Model Size Limits"
    category: "model_governance"
    check_type: "metadata_check"
    metadata_field: "size_mb"
    max_value: 100000
    min_value: 1
    message: "MODEL-002: Model size must be between 1MB and 100GB."
    severity: "error"

  - id: "MODEL-003"
    name: "No Backdoor Patterns"
    category: "model_security"
    check_type: "weight_analysis"
    description: |
      Model weights are analyzed for statistical anomalies that may
      indicate adversarial backdoors or trojan patterns.
    message: "MODEL-003: Weight analysis detected potential backdoor patterns."
    severity: "blocker"

  - id: "MODEL-004"
    name: "Model License Verification"
    category: "model_governance"
    check_type: "license_check"
    allowed_licenses:
      - "MIT"
      - "Apache-2.0"
      - "BSD-3-Clause"
      - "CC-BY-4.0"
      - "Llama-2-Community"
      - "Gemma-Terms"
    message: "MODEL-004: Model license must be in approved list."
    severity: "error"

  - id: "MODEL-005"
    name: "Quantization Transparency"
    category: "model_governance"
    check_type: "metadata_check"
    metadata_field: "quantization"
    message: "MODEL-005: Quantization method must be documented."
    severity: "warning"

# =============================================================================
# SECTION 6: FILESYSTEM RULES
# Rules for safe file system access
# =============================================================================

  - id: "RI-08"
    name: "Uncontrolled File System Write"
    category: "filesystem"
    pattern: "open\\s*\\([^)]*['\"]w['\"]"
    message: "RI-08: Direct file writes should use controlled storage API."
    severity: "warning"
    mitigation: "Use 'from anchor.storage import SecureWriter' for file operations."

  - id: "RI-08-SHUTIL"
    name: "Bulk File Operations"
    category: "filesystem"
    match:
      type: "import"
      module: "shutil"
    message: "RI-08: Bulk file operations (shutil) require review."
    severity: "warning"

  - id: "RI-08-TEMPFILE"
    name: "Temporary File Creation"
    category: "filesystem"
    match:
      type: "import"
      module: "tempfile"
    message: "RI-08: Temp file usage is allowed but monitored."
    severity: "info"

# =============================================================================
# SECTION 7: AI-SPECIFIC RISKS (GenAI Threat Model)
# =============================================================================

  - id: "AI-20"
    name: "Model Hallucination Risk"
    category: "ai_safety"
    check_type: "output_validation"
    description: |
      AI model outputs must be validated before being used in code paths
      that affect business logic, financial calculations, or security decisions.
    message: "AI-20: Model outputs require validation before critical operations."
    severity: "warning"

  - id: "AI-21"
    name: "Prompt Injection Vulnerability"
    category: "ai_safety"
    pattern: "(user_input|prompt).*\\+.*\\.format\\("
    message: "AI-21: Potential prompt injection - validate and sanitize inputs."
    severity: "error"

  - id: "AI-22"
    name: "Training Data Poisoning"
    category: "ai_safety"
    check_type: "data_integrity"
    message: "AI-22: Training data integrity must be verified."
    severity: "blocker"

# =============================================================================
# END OF CONSTITUTION
# To add project-specific rules, create a policy.anchor file in your repo.
# =============================================================================
