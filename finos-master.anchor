# =============================================================================
# FINOS AI Governance Framework - Universal Constitution
# =============================================================================
# Version: 2.4.16-OFFICIAL
# Status: PRODUCTION
# Authority: FINOS (Fintech Open Source Foundation)
# 
# This file represents the "Federal Law" - universal rules that ALL projects
# under FINOS governance must follow. Individual projects can extend but
# CANNOT weaken these rules.
#
# Rule IDs (RI-*) are mapped directly to the Official FINOS Risk Taxonomy.
# =============================================================================

version: "2.4.16"

metadata:
  framework: "FINOS AI Governance Framework"
  version: "2025.Q1.Spec"
  last_updated: "2026-02-09"
  maintainer: "FINOS AI Security Working Group"
  repository: "https://github.com/finos/ai-governance-framework"
  
# =============================================================================
# SECTION 1: PROMPT & INPUT GOVERNANCE (RI-10, RI-25)
# =============================================================================

rules:
  - id: "RI-10-PI"
    name: "Prompt Injection - Unsanitized Input Concatenation"
    category: "security"
    description: |
      LLMs do not distinguish between instructions and data. Concatenating user
      input directly into prompt strings creates a direct prompt injection vector.
    match:
      type: "regex"
      pattern: "(prompt|system_msg|query).*[:=].*f?['\"].*\\{.*(user_input|data|req).*\\}.*['\"]"
    message: "RI-10: Potential Prompt Injection via f-string concatenation. Use Template classes with strict schema enforcement."
    severity: "error"
    mitigation: "Use 'from anchor.ai import PromptTemplate' to isolate instructions from untrusted data."
    references:
      - "OWASP:LLM01-2025"
      - "MITRE:T1055"

  - id: "RI-25-TCM"
    name: "Tool Chain Manipulation - Unchecked Parameters"
    category: "security"
    description: |
      Adversaries can manipulate agents into passing malicious parameters to 
      legitimate tools (e.g., modified account numbers or amounts).
    match:
      type: "function_call"
      name: "call_tool"
      check_params: true
    message: "RI-25: Tool calls must implement dynamic parameter validation."
    severity: "blocker"
    mitigation: "Implement Pydantic-based validation on all agent tool schemas."

# =============================================================================
# SECTION 2: INFORMATION LEAKAGE & PRIVACY (RI-01, RI-02)
# =============================================================================

  - id: "RI-01-HL"
    name: "Information Leakage to Hosted Models"
    category: "data_privacy"
    description: |
      Sending sensitive PII or corporate secrets to third-party hosted models
      risks memorization and secondary exfiltration.
    match:
      type: "regex"
      pattern: "(api\\.openai\\.com|anthropic\\.com|base_url.*['\"]http)"
    message: "RI-01: Direct connection to public LLM endpoints requires the Enterprise Proxy."
    severity: "blocker"
    mitigation: "Use 'from anchor.net import HostedModelGate' to ensure data sanitization before egress."
    references:
      - "NIST-AI-600-1:2.4"
      - "GDPR-Article-32"

  - id: "RI-02-VS"
    name: "Information Leakage to Vector Stores"
    category: "data_privacy"
    match:
      type: "import"
      module: "pinecone"
    message: "RI-02: Vector store indexing of sensitive data requires PII scrubbing."
    severity: "error"
    mitigation: "Enable 'anchor: privacy-scrub' in the ingest pipeline."

# =============================================================================
# SECTION 3: AGENTIC PRIVILEGE & BOUNDARIES (RI-24, RI-28)
# =============================================================================

  - id: "RI-24-EA"
    name: "Excessive Agency - Unauthorized System Access"
    category: "security"
    description: |
      Agents must not have direct access to system-level APIs (subprocess, os)
      unless isolated within a deterministic sandbox.
    match:
      type: "import"
      module: "subprocess"
    message: "RI-24: Direct subprocess usage in agent handlers is forbidden. Use Diamond Cage (WASM)."
    severity: "blocker"
    mitigation: "Refactor to use 'anchor.core.sandbox.DiamondCage' for all side-effects."
    references:
      - "OWASP:LLM06-2025"

  - id: "RI-28-TB"
    name: "Multi-Agent Trust Boundary Violation"
    category: "security"
    match:
      type: "function_call"
      name: "transfer_state"
    message: "RI-28: State transfer between agents must be signed and verified."
    severity: "error"
    mitigation: "Implement 'anchor.crypto.StateSigner' for cross-agent communication."

# =============================================================================
# SECTION 4: SUPPLY CHAIN & MCP (RI-26)
# =============================================================================

  - id: "RI-26-MCP"
    name: "MCP Server Supply Chain Compromise"
    category: "supply_chain"
    description: |
      Unverified MCP (Model Context Protocol) servers can inject tainted data
      or logic into the agent reasoning loop.
    match:
      type: "regex"
      pattern: "mcp_server_url.*=.*['\"](?!https://approved\\.internal).*['\"]"
    message: "RI-26: Connection to unverified MCP server detected."
    severity: "blocker"
    mitigation: "Whitelist MCP servers in the project policy.anchor file."
    references:
      - "NIST-SCRM:Software-Supply-Chain"

# =============================================================================
# SECTION 5: MODEL INTEGRITY (RI-08, RI-09)
# =============================================================================

  - id: "RI-08-TM"
    name: "Tampering with Foundational Model (Weights)"
    category: "model_security"
    check_type: "weight_analysis"
    message: "RI-08: Model weight anomaly detected. Potential backdoor/trojan."
    severity: "blocker"

  - id: "RI-09-DP"
    name: "Data Poisoning - Training Feedback Loop"
    category: "model_security"
    match:
      type: "function_call"
      name: "fine_tune"
    message: "RI-09: Unverified user data used for fine-tuning risks poisoning."
    severity: "error"
    mitigation: "Enable 'clean_room' validation for all fine-tuning datasets."

# =============================================================================
# END OF OFFICIAL CONSTITUTION
# =============================================================================
